# Node / TypeScript
node_modules
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
/dist/
/build/
/out/
/.turbo/

# Frontend / backend specific
frontend/dist/
frontend/.vite/
backend/dist/
backend/.tsbuildinfo

# Package build outputs
packages/*/dist/

# Per-workspace lockfiles (single root lockfile via pnpm workspaces)
backend/pnpm-lock.yaml
frontend/pnpm-lock.yaml
packages/*/pnpm-lock.yaml

# Coverage
coverage/

# Test results (Playwright)
/test/results/
/test/e2e/mock-camunda/.generated/

# Env & secrets
.env
.env.*
*.local
.local/
.github_token

!.env.example
!**/.env.example
!infra/docker/env/examples/*.example
!infra/kubernetes/openshift/examples/*.example.yaml

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
.windsurf/
*.swp

# Logs
logs/
*.log

# Misc
*.tgz
*.gz
.tmp/

# Local docs (not tracked)
/local-docs/
/archive/
