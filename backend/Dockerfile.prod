# syntax=docker/dockerfile:1.7
FROM node:24-bookworm-slim AS build

WORKDIR /repo

# Install pnpm globally
RUN npm install -g pnpm@11.0.8

# Copy workspace manifests for pnpm install layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY backend/package.json backend/
COPY packages/shared/package.json packages/shared/
COPY packages/backend-host/package.json packages/backend-host/
COPY packages/enterprise-plugin-api/package.json packages/enterprise-plugin-api/
COPY packages/frontend-host/package.json packages/frontend-host/
COPY frontend/package.json frontend/

# BuildKit cache mount hydrates pnpm store across builds. `sharing=locked` serializes
# concurrent multi-platform builds safely. --frozen-lockfile ensures reproducible installs.
RUN --mount=type=cache,target=/root/.local/share/pnpm/store,sharing=locked \
    pnpm install --frozen-lockfile

# Build OSS packages (shared must be built before backend-host)
COPY packages packages
RUN pnpm --filter shared run build
RUN pnpm --filter backend-host run build

COPY backend backend
RUN pnpm --filter webmodeler-backend run build:skip-generate

FROM node:24-bookworm-slim AS deps

WORKDIR /repo

# Install pnpm globally
RUN npm install -g pnpm@11.0.8

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY backend/package.json backend/
COPY packages/shared/package.json packages/shared/
COPY packages/backend-host/package.json packages/backend-host/
COPY packages/enterprise-plugin-api/package.json packages/enterprise-plugin-api/
COPY packages/frontend-host/package.json packages/frontend-host/
COPY frontend/package.json frontend/

# BuildKit cache mount for pnpm store — same rationale as the build stage above.
RUN --mount=type=cache,target=/root/.local/share/pnpm/store,sharing=locked \
    pnpm install --frozen-lockfile \
    && pnpm add --filter webmodeler-backend --save-dev mysql2 mssql

FROM cgr.dev/chainguard/node:latest-dev AS runtime-base
USER root
RUN apk upgrade --no-cache \
    && apk del --no-network npm \
    && rm -rf /usr/lib/node_modules/npm /usr/bin/npm /usr/bin/npx
USER 65532

FROM runtime-base

WORKDIR /app
ENV NODE_ENV=production

COPY backend/package.json ./package.json

# The compiled backend runs from /app/dist/backend/src. With pnpm, package
# dependencies are symlinks from each workspace package's node_modules into the
# root .pnpm store, so copy that same layout under /app/dist for Node's module
# resolver.
COPY --from=deps /repo/node_modules ./dist/node_modules
COPY --from=deps /repo/backend/node_modules ./dist/backend/node_modules
COPY --from=deps /repo/packages/backend-host/node_modules ./dist/packages/backend-host/node_modules
COPY --from=deps /repo/packages/shared/node_modules ./dist/packages/shared/node_modules

COPY --from=build /repo/backend/dist ./dist
COPY --from=build /repo/packages/shared/src/db/adapters/sql ./packages/shared/src/db/adapters/sql
COPY --from=build /repo/packages/shared/src/db/migrations ./packages/shared/src/db/migrations

EXPOSE 8787

USER 65532

CMD ["dist/backend/src/server.js"]
