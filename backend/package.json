{
  "name": "webmodeler-backend",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/resolve-dist-imports.mjs",
    "build:skip-generate": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/resolve-dist-imports.mjs",
    "start:compiled": "node dist/backend/src/server.js",
    "typecheck": "tsc --noEmit",
    "guard:no-raw-sql": "tsx scripts/check-no-raw-sql.ts",
    "test:unit": "npm run guard:no-raw-sql && vitest --run --dir __tests__ --config vitest.config.ts",
    "test:integration": "npm run guard:no-raw-sql && vitest --run --dir test/integration --config vitest.config.ts --fileParallelism=false",
    "verify": "npm run typecheck && npm run build:skip-generate && npm run test:unit",
    "db:migration:generate": "npx typeorm migration:generate -d dist/packages/shared/src/db/data-source.js",
    "db:migration:run": "npx typeorm migration:run -d dist/packages/shared/src/db/data-source.js",
    "db:migration:revert": "npx typeorm migration:revert -d dist/packages/shared/src/db/data-source.js",
    "db:schema:sync": "npx typeorm schema:sync -d dist/packages/shared/src/db/data-source.js",
    "db:cleanup-test-data": "tsx scripts/cleanup-test-data.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@azure/msal-node": "^5.0.6",
    "@gitbeaker/rest": "^43.8.0",
    "@node-saml/node-saml": "^5.1.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "azure-devops-node-api": "^15.1.1",
    "bcryptjs": "^3.0.3",
    "bitbucket": "^2.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.1",
    "octokit": "^5.0.5",
    "oracledb": "^6.0.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.4.1",
    "simple-git": "^3.32.3",
    "sql.js": "^1.13.0",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.28",
    "undici": "^7.24.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterpriseglue/shared": "*",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.6",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "esbuild": "^0.27.2",
    "cookie": "^0.7.0",
    "lodash": "^4.17.23",
    "minimatch": "^10.2.4",
    "cross-spawn": "^7.0.6",
    "tar": "^7.5.8",
    "brace-expansion": "^2.0.2",
    "diff": "^5.2.2",
    "fast-xml-parser": "^5.3.6",
    "qs": "^6.14.2",
    "underscore": "^1.13.8",
    "@tootallnate/once": "^3.0.1"
  }
}
