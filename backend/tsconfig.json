{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "vitest/globals"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@enterpriseglue/shared/db/adapters/*": ["../packages/shared/src/infrastructure/persistence/adapters/*"],
      "@enterpriseglue/shared/db/entities/*": ["../packages/shared/src/infrastructure/persistence/entities/*"],
      "@enterpriseglue/shared/contracts": ["../packages/shared/src/contracts/index.d.ts"],
      "@enterpriseglue/shared/contracts/auth": ["../packages/shared/src/contracts/auth.d.ts"],
      "@enterpriseglue/shared/contracts/roles": ["../packages/shared/src/contracts/roles.d.ts"],
      "@enterpriseglue/shared/contracts/members": ["../packages/shared/src/contracts/members.d.ts"],
      "@enterpriseglue/shared/*": ["../packages/shared/src/*"],
      "@enterpriseglue/backend-host/*": ["../packages/backend-host/src/*"],
      "@modules/*": ["../packages/backend-host/src/modules/*"],
      "@vitest/expect": ["./node_modules/@vitest/expect/dist/index.d.ts"],
      "@enterpriseglue/enterprise-plugin-api": ["../packages/enterprise-plugin-api/src/index.d.ts"],
      "@enterpriseglue/enterprise-plugin-api/backend": ["../packages/enterprise-plugin-api/src/backend.d.ts"],
      "@enterpriseglue/enterprise-plugin-api/frontend": ["../packages/enterprise-plugin-api/src/frontend.d.ts"]
    },
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts", "__tests__/**/*.ts", "../packages/backend-host/src/**/*.ts", "../packages/shared/src/types/**/*.d.ts"],
  "exclude": ["src/db/schema/drizzle-kit-schema.ts"]
}
