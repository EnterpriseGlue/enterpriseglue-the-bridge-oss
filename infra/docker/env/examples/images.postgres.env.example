NODE_ENV=production

# Published image references
# Use your own registry namespace if different from GHCR default.
BACKEND_IMAGE=ghcr.io/your-org/enterpriseglue-the-bridge-oss-backend
FRONTEND_IMAGE=ghcr.io/your-org/enterpriseglue-the-bridge-oss-frontend
# Examples: sha-<commit> or vX.Y.Z
IMAGE_TAG=v0.1.0
# Backend container env file path consumed by docker-compose.prod.yml.
# After copying this template, keep this value pointing to your copied file.
EG_BACKEND_ENV_FILE=./.local/docker/env/images.postgres.env

# Frontend + backend exposure
API_PORT=8787
FRONTEND_HOST_PORT=8080
FRONTEND_URL=http://localhost:8080
# Keep backend internal-only by default in production.
EXPOSE_BACKEND=false
# Used only when EXPOSE_BACKEND=true with docker-compose.backend-expose.yml
BACKEND_HOST_PORT=8787

# Database
DATABASE_TYPE=postgres
POSTGRES_SCHEMA=main
POSTGRES_USER=enterpriseglue
POSTGRES_PASSWORD=change_me
POSTGRES_DB=enterpriseglue
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DATABASE=enterpriseglue
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Auth + crypto
JWT_SECRET=change_me_change_me_change_me_change_me
ADMIN_EMAIL=admin@enterpriseglue.ai
ADMIN_PASSWORD=change_me_change_me
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Git
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main

# Frontend build/runtime
# Keep empty for same-origin API calls through Nginx proxy.
API_BASE_URL=
