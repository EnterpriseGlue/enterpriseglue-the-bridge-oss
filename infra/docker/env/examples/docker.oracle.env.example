NODE_ENV=development

# Backend + frontend ports
API_PORT=8787
BACKEND_HOST_PORT=8787
EXPOSE_BACKEND=true
FRONTEND_HOST_PORT=5173
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_TYPE=oracle

# Preferred: connection string (Easy Connect Plus or TNS descriptor)
# Examples:
#   ORACLE_CONNECTION_STRING=db:1521/XEPDB1
#   ORACLE_CONNECTION_STRING=host1:1521,host2:1521/XEPDB1
#   ORACLE_CONNECTION_STRING=(DESCRIPTION=(FAILOVER=on)(LOAD_BALANCE=on)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=host1)(PORT=1521))(ADDRESS=(PROTOCOL=TCP)(HOST=host2)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=XEPDB1)))
ORACLE_CONNECTION_STRING=db:1521/XEPDB1

ORACLE_USER=enterpriseglue
ORACLE_PASSWORD=oracle
ORACLE_SCHEMA=ENTERPRISEGLUE

# Fallback: single-host variables (used when ORACLE_CONNECTION_STRING is empty)
ORACLE_HOST=db
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_HOST_PORT=1521

# Auth + crypto (dev defaults)
JWT_SECRET=dev_jwt_secret_change_me_please_32_chars
ADMIN_EMAIL=admin@enterpriseglue.ai
ADMIN_PASSWORD=dev_admin_password_change_me
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Git
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main

# Frontend runtime
API_BASE_URL=
VITE_FEATURE_VOYAGER=true
VITE_FEATURE_STARBASE=true
VITE_FEATURE_MISSION_CONTROL=true
VITE_FEATURE_ENGINES=true
VITE_FEATURE_MC_PROCESSES=true
VITE_FEATURE_MC_BATCHES=true
VITE_FEATURE_MC_DECISIONS=true
VITE_FEATURE_SB_PROJECTS=true
VITE_FEATURE_SB_FILES=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_USER_MENU=true
