NODE_ENV=production

# Published image references
# GHCR (default, always published):
BACKEND_IMAGE=ghcr.io/enterpriseglue/enterpriseglue-the-bridge-oss-backend
FRONTEND_IMAGE=ghcr.io/enterpriseglue/enterpriseglue-the-bridge-oss-frontend
# Docker Hub alternative (also published):
# BACKEND_IMAGE=docker.io/enterpriseglue/enterpriseglue-the-bridge-oss-backend
# FRONTEND_IMAGE=docker.io/enterpriseglue/enterpriseglue-the-bridge-oss-frontend
# Use 'latest' for the most recent release, or pin to a specific tag e.g. v1.2.3
IMAGE_TAG=latest
# Backend container env file path consumed by docker-compose.prod.yml.
# After copying this template, keep this value pointing to your copied file.
EG_BACKEND_ENV_FILE=./.local/docker/env/images.oracle.env

# Frontend + backend exposure
API_PORT=8787
FRONTEND_HOST_PORT=8080
FRONTEND_URL=http://localhost:8080
# Keep backend internal-only by default in production.
EXPOSE_BACKEND=false
# Used only when EXPOSE_BACKEND=true with docker-compose.backend-expose.yml
BACKEND_HOST_PORT=8787

# Database
DATABASE_TYPE=oracle
ORACLE_HOST=db
ORACLE_PORT=1521
ORACLE_USER=enterpriseglue
ORACLE_PASSWORD=change_me
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_SCHEMA=ENTERPRISEGLUE
ORACLE_HOST_PORT=1521

# Auth + crypto
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=change_me_change_me_change_me_change_me
ADMIN_EMAIL=admin@enterpriseglue.ai
# Generate ADMIN_PASSWORD: openssl rand -base64 16
ADMIN_PASSWORD=change_me_change_me
# Generate ENCRYPTION_KEY: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Git
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main

# Frontend build/runtime
# Keep empty for same-origin API calls through Nginx proxy.
API_BASE_URL=
