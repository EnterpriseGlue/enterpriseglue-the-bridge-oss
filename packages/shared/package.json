{
  "name": "@enterpriseglue/shared",
  "version": "0.1.0",
  "description": "Shared utilities, contracts, and services for EnterpriseGlue",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicholasgriffintn/enterpriseglue-the-bridge-oss.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "types": "./dist/contracts/index.d.ts",
  "scripts": {
    "build": "tsc && npm run build:copy",
    "build:copy": "cp -r src/db/adapters/sql dist/db/adapters/ && cp src/contracts/members.d.ts src/contracts/members.js src/contracts/roles.d.ts src/contracts/roles.js dist/contracts/",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.sql"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.0",
    "@gitbeaker/rest": "^43.8.0",
    "azure-devops-node-api": "^15.1.1",
    "bcryptjs": "^3.0.3",
    "bitbucket": "^2.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.12",
    "octokit": "^5.0.5",
    "oracledb": "^6.0.0",
    "pg": "^8.11.3",
    "resend": "^6.4.1",
    "typeorm": "^0.3.28",
    "undici": "^7.18.2",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.16.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.3"
  },
  "exports": {
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./contracts/auth": {
      "types": "./dist/contracts/auth.d.ts",
      "default": "./dist/contracts/auth.js"
    },
    "./contracts/roles": {
      "types": "./dist/contracts/roles.d.ts",
      "default": "./dist/contracts/roles.js"
    },
    "./contracts/members": {
      "types": "./dist/contracts/members.d.ts",
      "default": "./dist/contracts/members.js"
    },
    "./*": "./dist/*"
  }
}
