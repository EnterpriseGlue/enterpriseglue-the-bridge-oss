{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "@enterpriseglue/shared/*": ["../shared/dist/*", "../shared/src/*"],
      "@modules/*": ["./src/modules/*"],
      "@enterpriseglue/enterprise-plugin-api": ["../enterprise-plugin-api/src/index.d.ts"],
      "@enterpriseglue/enterprise-plugin-api/backend": ["../enterprise-plugin-api/src/backend.d.ts"]
    },
    "outDir": "dist",
    "declaration": true
  },
  "include": ["src/**/*.ts", "../shared/src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
