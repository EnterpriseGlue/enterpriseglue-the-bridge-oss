{
  "name": "@enterpriseglue/backend-host",
  "version": "0.1.0",
  "description": "OSS backend host for EnterpriseGlue — Express app, route modules, enterprise loader, and server bootstrap",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicholasgriffintn/enterpriseglue-the-bridge-oss.git",
    "directory": "packages/backend-host"
  },
  "private": true,
  "type": "module",
  "files": [
    "src/**/*.ts",
    "src/**/*.js"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    "./server": "./src/server.ts",
    "./app": "./src/app.ts",
    "./enterprise/*": "./src/enterprise/*",
    "./modules/*": "./src/modules/*",
    "./routes": "./src/routes/index.ts"
  }
}
