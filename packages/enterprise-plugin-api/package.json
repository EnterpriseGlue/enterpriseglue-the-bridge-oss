{
  "name": "@enterpriseglue/enterprise-plugin-api",
  "version": "0.2.1",
  "description": "Plugin API contract types for EnterpriseGlue OSS/EE boundary",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./backend": {
      "types": "./src/backend.d.ts",
      "default": "./src/backend.js"
    },
    "./frontend": {
      "types": "./src/frontend.d.ts",
      "default": "./src/frontend.js"
    }
  },
  "files": [
    "src/**/*.d.ts",
    "src/**/*.js",
    "src/**/*.ts",
    "fixtures/"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnterpriseGlue/enterpriseglue-the-bridge-oss.git",
    "directory": "packages/enterprise-plugin-api"
  }
}
