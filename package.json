{
  "scripts": {
    "dev": "bash ./dev.sh",
    "down": "bash ./down.sh",
    "prod": "docker compose --project-directory . --env-file .env.production -f infra/docker/compose/docker-compose.prod.yml up --build",
    "prod:down": "docker compose --project-directory . --env-file .env.production -f infra/docker/compose/docker-compose.prod.yml down",
    "prod:images:postgres": "docker compose --project-directory . --env-file .env.images.postgres -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.images.yml up -d",
    "prod:images:postgres:down": "docker compose --project-directory . --env-file .env.images.postgres -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.images.yml down",
    "prod:images:oracle": "docker compose --project-directory . --env-file .env.images.oracle -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.oracle.yml -f infra/docker/compose/docker-compose.images.yml up -d",
    "prod:images:oracle:down": "docker compose --project-directory . --env-file .env.images.oracle -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.oracle.yml -f infra/docker/compose/docker-compose.images.yml down",
    "smoke:images:local": "bash ./scripts/smoke-images-local.sh",
    "smoke:images:local:fast": "bash ./scripts/smoke-images-local.sh --skip-oracle",
    "smoke:images:local:auth:fast": "bash ./scripts/smoke-images-local.sh --skip-oracle --skip-exposed",
    "deploy:openshift": "bash ./scripts/deploy-openshift.sh",
    "deploy:openshift:skip-health": "SKIP_EXTERNAL_HEALTHCHECK=true bash ./scripts/deploy-openshift.sh",
    "deploy:localhost": "bash ./scripts/deploy-localhost.sh",
    "build": "docker compose --project-directory . --env-file .env.docker -f infra/docker/compose/docker-compose.yml build",
    "typecheck": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "test:unit": "npm --prefix backend run test:unit && npm --prefix frontend run test:unit",
    "test:integration": "npm --prefix backend run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:smoke:oracle:images": "bash ./scripts/e2e-smoke-oracle.sh",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e && npm --prefix backend run db:cleanup-test-data",
    "test:ci:pr": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke && npm --prefix backend run db:cleanup-test-data"
  },
  "dependencies": {
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  }
}
