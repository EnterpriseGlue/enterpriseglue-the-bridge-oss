{
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash ./dev.sh",
    "down": "bash ./down.sh",
    "prod": "ENV_FILE=.local/docker/env/production.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.production; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml up --build",
    "prod:down": "ENV_FILE=.local/docker/env/production.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.production; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml down",
    "prod:images:postgres": "ENV_FILE=.local/docker/env/images.postgres.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.images.postgres; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.images.yml up -d",
    "prod:images:postgres:down": "ENV_FILE=.local/docker/env/images.postgres.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.images.postgres; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.images.yml down",
    "prod:images:oracle": "ENV_FILE=.local/docker/env/images.oracle.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.images.oracle; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.oracle.yml -f infra/docker/compose/docker-compose.images.yml up -d",
    "prod:images:oracle:down": "ENV_FILE=.local/docker/env/images.oracle.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.images.oracle; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.prod.yml -f infra/docker/compose/docker-compose.oracle.yml -f infra/docker/compose/docker-compose.images.yml down",
    "smoke:images:local": "bash ./scripts/smoke-images-local.sh",
    "smoke:images:local:fast": "bash ./scripts/smoke-images-local.sh --skip-oracle",
    "smoke:images:local:auth:fast": "bash ./scripts/smoke-images-local.sh --skip-oracle --skip-exposed",
    "deploy:openshift": "bash ./scripts/deploy-openshift.sh",
    "deploy:openshift:skip-health": "SKIP_EXTERNAL_HEALTHCHECK=true bash ./scripts/deploy-openshift.sh",
    "deploy:localhost": "bash ./scripts/deploy-localhost.sh",
    "build": "ENV_FILE=.local/docker/env/docker.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=.env.docker; EG_BACKEND_ENV_FILE=\"$ENV_FILE\" docker compose --project-directory . --env-file \"$ENV_FILE\" -f infra/docker/compose/docker-compose.yml build",
    "typecheck": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "test:unit": "npm --prefix backend run test:unit && npm --prefix frontend run test:unit",
    "test:integration": "npm --prefix backend run test:integration",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test --config test/e2e/playwright.config.ts --grep @smoke",
    "test:e2e:smoke:oracle:images": "bash ./scripts/e2e-smoke-oracle.sh",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e && npm --prefix backend run db:cleanup-test-data",
    "test:ci:pr": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke && npm --prefix backend run db:cleanup-test-data",
    "guard:oss-ee-boundary": "bash ./scripts/check-oss-ee-boundary.sh",
    "guard:plugin-api:current": "bash ./scripts/check-plugin-api-compat.sh current",
    "guard:plugin-api:next": "bash ./scripts/check-plugin-api-compat.sh next",
    "guard:plugin-boot:oss": "bash ./scripts/check-plugin-boot-mode.sh oss",
    "plugin-api:pack": "mkdir -p ./.artifacts && cd packages/enterprise-plugin-api && npm pack && mv *.tgz ../../.artifacts/",
    "ci:watch": "bash ./scripts/ci-watch.sh",
    "ci:watch:trigger": "bash ./scripts/ci-watch.sh docker-images --trigger"
  },
  "dependencies": {
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  },
  "overrides": {
    "react-split-pane": {
      "react": "^19.1.1",
      "react-dom": "^19.1.1"
    },
    "dompurify": "3.3.2",
    "immutable": "5.1.5",
    "esbuild": "^0.27.2",
    "cookie": "^0.7.0",
    "lodash": "^4.17.23",
    "lodash-es": "4.17.23",
    "minimatch": "^10.2.4",
    "cross-spawn": "^7.0.6",
    "glob": "^10.5.0",
    "tar": "^7.5.8",
    "brace-expansion": "^2.0.2",
    "diff": "^5.2.2",
    "fast-xml-parser": "^5.3.6",
    "qs": "^6.14.2",
    "underscore": "^1.13.8",
    "@tootallnate/once": "^3.0.1",
    "preact": "10.28.2",
    "ids": "^3.0.0"
  }
}
